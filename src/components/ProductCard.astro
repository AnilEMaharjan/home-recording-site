---
interface Retailer {
  name: string;
  url: string;
}

interface Props {
  name: string;
  price: number;
  rating: number;
  reviewCount: number;
  retailers: Retailer[];
  badge?: string;
  description?: string;
}

const { name, price, rating, reviewCount, retailers = [], badge, description } = Astro.props;
const [primary, ...secondary] = retailers;
const stars = Math.round(rating);
---

<div class="border border-gray-200 rounded-xl p-5 flex flex-col gap-3">
  {badge && (
    <span class="inline-block self-start bg-blue-600 text-white text-xs font-semibold px-2 py-0.5 rounded">
      {badge}
    </span>
  )}

  <div>
    <h3 class="font-semibold text-gray-900 text-lg">{name}</h3>
    {description && <p class="text-gray-600 text-sm mt-1">{description}</p>}
  </div>

  <div class="flex items-center gap-3">
    <span class="text-2xl font-bold text-gray-900">${price.toFixed(2)}</span>
    <span class="text-sm text-gray-500">
      {'★'.repeat(stars)}{'☆'.repeat(5 - stars)} ({reviewCount.toLocaleString()} reviews)
    </span>
  </div>

  <a
    href={primary.url}
    target="_blank"
    rel="noopener noreferrer sponsored"
    class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold text-center py-2.5 px-4 rounded-lg transition-colors"
  >
    Check Price at {primary.name}
  </a>

  {secondary.length > 0 && (
    <p class="text-xs text-gray-500">
      Also at:{' '}
      {secondary.map((r, i) => (
        <>
          <a href={r.url} target="_blank" rel="noopener noreferrer sponsored" class="text-blue-500 hover:underline">
            {r.name}
          </a>
          {i < secondary.length - 1 && ' · '}
        </>
      ))}
    </p>
  )}
</div>
